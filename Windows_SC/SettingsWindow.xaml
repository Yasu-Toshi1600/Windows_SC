<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Windows_SC.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Windows_SC 設定">

    <Grid x:Name="RootGrid" Padding="24" RowDefinitions="Auto,*,Auto" RowSpacing="16">
        <Border Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
        <Grid ColumnDefinitions="*,180,Auto,Auto" ColumnSpacing="16">
            <StackPanel Spacing="4">
                <TextBlock FontSize="24" FontWeight="SemiBold" Text="ランチャー設定" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="項目とボタンの実行内容を編集します" />
            </StackPanel>
            <ComboBox Grid.Column="1"
                      Header="配置"
                      DisplayMemberPath="DisplayName"
                      ItemsSource="{Binding LayoutModes}"
                      SelectedItem="{Binding SelectedLayoutMode, Mode=TwoWay}" />
            <ToggleSwitch Grid.Column="2"
                          Header="スマートフォン連携"
                          IsOn="{Binding AssumePhonePanelVisible, Mode=TwoWay}"
                          OffContent="なし"
                          OnContent="あり" />
            <ToggleSwitch Grid.Column="3"
                          Header="Windowsログイン時"
                          IsOn="{Binding StartWithWindows, Mode=TwoWay}"
                          OffContent="起動しない"
                          OnContent="自動起動" />
        </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,16,430">
            <Border Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="項目" />
                <ListView x:Name="LauncherItemsList"
                          Grid.Row="1"
                          ItemsSource="{Binding Items}"
                          SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,2"
                                    Padding="8"
                                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="6">
                                <TextBlock VerticalAlignment="Center" Text="{Binding Title}" />
                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Text="{Binding KindDisplayName}" />
                                <Button Grid.Column="2"
                                        Click="LauncherItemMoveUp_Click"
                                        Content="↑"
                                        Padding="8,4"
                                        ToolTipService.ToolTip="上へ移動" />
                                <Button Grid.Column="3"
                                        Click="LauncherItemMoveDown_Click"
                                        Content="↓"
                                        Padding="8,4"
                                        ToolTipService.ToolTip="下へ移動" />
                                <Button Grid.Column="4"
                                        Click="LauncherItemRemove_Click"
                                        Content="×"
                                        Padding="8,4"
                                        ToolTipService.ToolTip="削除" />
                            </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                    <Button Command="{Binding AddButtonCommand}" Content="ボタン追加" />
                    <Button Command="{Binding AddToggleCommand}" Content="循環切り替え追加" />
                    <Button Command="{Binding AddSliderCommand}" Content="スライダー追加" />
                </StackPanel>
            </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="選択項目" />
                    <TextBox Header="表示名"
                             Text="{Binding SelectedItem.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Header="種類" IsReadOnly="True" Text="{Binding SelectedItem.KindDisplayName}" />
                    <ComboBox Header="実行後"
                              DisplayMemberPath="DisplayName"
                              ItemsSource="{Binding PostExecutionBehaviors}"
                              SelectedValue="{Binding SelectedItem.PostExecutionBehavior, Mode=TwoWay}"
                              SelectedValuePath="Value"
                              Visibility="{Binding SelectedItem.PostExecutionSettingsVisibility}" />
                    <StackPanel Spacing="12"
                                Visibility="{Binding SelectedItem.ButtonSettingsVisibility}">
                        <ComboBox Header="実行種類"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding ActionKinds}"
                                  SelectedItem="{Binding SelectedActionKind, Mode=TwoWay}" />
                        <TextBox Header="起動対象"
                                 PlaceholderText="アプリ名、ファイルのパス、URL"
                                 Text="{Binding SelectedItem.Target, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Header="引数"
                                 Text="{Binding SelectedItem.Arguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Header="作業フォルダー（通常は空欄）"
                                 Text="{Binding SelectedItem.WorkingDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <CheckBox Content="コマンド／batの画面を表示しない"
                                  IsChecked="{Binding SelectedItem.HideCommandWindow, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Spacing="12"
                                Visibility="{Binding SelectedItem.CycleSettingsVisibility}">
                        <ComboBox Header="切り替え内容"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding CycleKinds}"
                                  SelectedItem="{Binding SelectedCycleKind, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Spacing="12"
                                Visibility="{Binding SelectedItem.AudioDeviceSettingsVisibility}">
                        <TextBlock FontWeight="SemiBold" Text="音声出力の切り替え順" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="2台以上登録すると、上から順番に切り替えます。"
                                   TextWrapping="Wrap" />
                        <ComboBox Header="追加するデバイス"
                                  DisplayMemberPath="DisplayLabel"
                                  ItemsSource="{Binding AvailableAudioOutputDevices}"
                                  SelectedItem="{Binding AudioDeviceToAdd, Mode=TwoWay}" />
                        <Button HorizontalAlignment="Left"
                                Command="{Binding AddAudioDeviceCommand}"
                                Content="一覧に追加" />
                        <ListView x:Name="AudioDeviceList"
                                  Height="180"
                                  ItemsSource="{Binding SelectedItem.RegisteredAudioDevices}"
                                  SelectedItem="{Binding SelectedRegisteredAudioDevice, Mode=TwoWay}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="4">
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="{Binding DisplayLabel}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Button Grid.Column="1"
                                                Click="AudioDeviceMoveUp_Click"
                                                Content="↑"
                                                Padding="8,4"
                                                ToolTipService.ToolTip="上へ移動" />
                                        <Button Grid.Column="2"
                                                Click="AudioDeviceMoveDown_Click"
                                                Content="↓"
                                                Padding="8,4"
                                                ToolTipService.ToolTip="下へ移動" />
                                        <Button Grid.Column="3"
                                                Click="AudioDeviceRemove_Click"
                                                Content="×"
                                                Padding="8,4"
                                                ToolTipService.ToolTip="削除" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                    <StackPanel Spacing="12"
                                Visibility="{Binding SelectedItem.CommandCycleSettingsVisibility}">
                        <TextBlock FontWeight="SemiBold" Text="コマンドの実行順" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="2つ以上登録すると、上から順番に実行します。"
                                   TextWrapping="Wrap" />
                        <CheckBox Content="失敗時は同じ操作を再実行する"
                                  IsChecked="{Binding SelectedItem.RetryFailedCommand, Mode=TwoWay}" />
                        <Button HorizontalAlignment="Left"
                                Command="{Binding AddCommandStepCommand}"
                                Content="操作を追加" />
                        <ListView x:Name="CommandStepList"
                                  Height="150"
                                  ItemsSource="{Binding SelectedItem.CommandSteps}"
                                  SelectedItem="{Binding SelectedCommandStep, Mode=TwoWay}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="4">
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="{Binding DisplayName}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Button Grid.Column="1"
                                                Click="CommandStepMoveUp_Click"
                                                Content="↑"
                                                Padding="8,4"
                                                ToolTipService.ToolTip="上へ移動" />
                                        <Button Grid.Column="2"
                                                Click="CommandStepMoveDown_Click"
                                                Content="↓"
                                                Padding="8,4"
                                                ToolTipService.ToolTip="下へ移動" />
                                        <Button Grid.Column="3"
                                                Click="CommandStepRemove_Click"
                                                Content="×"
                                                Padding="8,4"
                                                ToolTipService.ToolTip="削除" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <TextBlock FontWeight="SemiBold" Text="選択中の操作" />
                        <TextBox Header="表示名"
                                 Text="{Binding SelectedCommandStep.DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Header="実行対象"
                                 PlaceholderText="例: DisplaySwitch.exe"
                                 Text="{Binding SelectedCommandStep.Target, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Header="引数"
                                 PlaceholderText="例: /extend"
                                 Text="{Binding SelectedCommandStep.Arguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Header="作業フォルダー（通常は空欄）"
                                 Text="{Binding SelectedCommandStep.WorkingDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <CheckBox Content="コマンド画面を表示しない"
                                  IsChecked="{Binding SelectedCommandStep.HideCommandWindow, Mode=TwoWay}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
            </Border>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="12">
            <Button Command="{Binding ExitApplicationCommand}"
                    Content="アプリを終了" />
            <Button Grid.Column="1"
                    Click="TroubleshootingButton_Click"
                    Content="トラブルシューティング" />
            <TextBlock Grid.Column="2"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{Binding StatusMessage}" />
            <Button Grid.Column="3"
                    Command="{Binding SaveCommand}"
                    Content="保存"
                    Style="{ThemeResource AccentButtonStyle}" />
        </Grid>

        <ContentDialog x:Name="TroubleshootingDialog"
                       Grid.RowSpan="3"
                       CloseButtonText="閉じる"
                       Title="トラブルシューティング">
            <StackPanel MinWidth="520" MaxWidth="620" Spacing="16">
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="問題の調査に使うログと環境情報を管理します。詳細ログでもファイルパスは匿名化されます。"
                           TextWrapping="Wrap" />

                <ToggleSwitch Header="詳細診断ログ"
                              IsOn="{Binding IsDetailedDiagnosticsEnabled, Mode=TwoWay}"
                              OffContent="無効"
                              OnContent="24時間有効" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="{Binding DetailedDiagnosticsStatus}"
                           TextWrapping="Wrap" />
                <InfoBar IsClosable="False"
                         IsOpen="True"
                         Message="切り替え後に［適用］を押してください。ログを共有する前に内容を確認してください。"
                         Severity="Informational" />
                <Button HorizontalAlignment="Left"
                        Click="ApplyDetailedDiagnostics_Click"
                        Content="詳細診断ログ設定を適用"
                        Style="{ThemeResource AccentButtonStyle}" />

                <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold" Text="通常ログ" />
                    <TextBlock FontFamily="Consolas"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{Binding NormalLogPath}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Text="詳細ログ" />
                    <TextBlock FontFamily="Consolas"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{Binding DetailedLogPath}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Click="OpenLogFolder_Click" Content="ログフォルダーを開く" />
                    <Button Click="CopyEnvironmentInfo_Click" Content="環境情報をコピー" />
                    <Button Click="DeleteLogs_Click" Content="ログを削除" />
                </StackPanel>
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="{Binding StatusMessage}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </ContentDialog>
    </Grid>
</Window>
