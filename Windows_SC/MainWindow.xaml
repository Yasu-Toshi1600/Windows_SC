<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Windows_SC.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:Windows_SC.ViewModels"
    Title="Windows_SC">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Border
        x:Name="RootBorder"
        Padding="20"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="12"
        KeyDown="RootBorder_KeyDown">
        <Grid RowDefinitions="Auto,*" RowSpacing="16">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Spacing="4">
                    <TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.Title, Mode=OneWay}" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.HotKeyDescription, Mode=OneWay}" />
                </StackPanel>

                <Button
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Command="{x:Bind ViewModel.OpenSettingsCommand, Mode=OneWay}"
                    Content="設定" />
            </Grid>

            <ScrollViewer
                x:Name="LauncherScrollViewer"
                Grid.Row="1"
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled"
                VerticalScrollBarVisibility="Auto"
                VerticalScrollMode="Enabled">
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Shortcuts, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout
                            MaximumRowsOrColumns="2"
                            MinColumnSpacing="12"
                            MinItemHeight="220"
                            MinItemWidth="220"
                            MinRowSpacing="12"
                            Orientation="Horizontal" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:LauncherItemViewModel">
                            <Button
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Content="{x:Bind Title, Mode=OneWay}" />
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
