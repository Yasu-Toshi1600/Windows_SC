<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Windows_SC.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Windows_SC.Controls"
    xmlns:viewModels="using:Windows_SC.ViewModels"
    Title="Windows_SC">

    <Grid x:Name="MotionViewport" Background="Transparent">
        <Grid x:Name="LauncherSurface">
            <Border
                x:Name="RootBorder"
                Padding="20"
                Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                KeyDown="RootBorder_KeyDown"
                PointerPressed="RootBorder_PointerPressed">
        <Grid RowDefinitions="Auto,*" RowSpacing="16">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Spacing="4">
                    <TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.Title, Mode=OneTime}" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.HotKeyDescription, Mode=OneTime}" />
                </StackPanel>

                <Button
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Command="{x:Bind ViewModel.OpenSettingsCommand, Mode=OneTime}"
                    Content="設定" />
            </Grid>

            <ScrollViewer
                x:Name="LauncherScrollViewer"
                Grid.Row="1"
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled"
                VerticalScrollBarVisibility="Auto"
                VerticalScrollMode="Enabled">
                <ItemsControl
                    x:Name="LauncherItemsControl"
                    ItemsSource="{x:Bind ViewModel.Shortcuts, Mode=OneTime}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <controls:AdaptiveLauncherPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="{Binding TileHeight, Mode=OneWay}">
                                <Button
                                    Margin="6"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Command="{Binding ExecuteCommand, Mode=OneTime}"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    ToolTipService.ToolTip="{Binding Title, Mode=OneTime}"
                                    Visibility="{Binding ButtonVisibility, Mode=OneTime}">
                                    <TextBlock
                                        MaxLines="2"
                                        Text="{Binding Title, Mode=OneTime}"
                                        TextAlignment="Center"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="Wrap" />
                                </Button>

                                <Border
                                    Margin="6"
                                    Padding="16"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Visibility="{Binding StandardToggleVisibility, Mode=OneWay}">
                                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            MaxLines="2"
                                            Text="{Binding Title, Mode=OneTime}"
                                            TextTrimming="CharacterEllipsis"
                                            ToolTipService.ToolTip="{Binding Title, Mode=OneTime}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            Grid.Row="1"
                                            MaxLines="2"
                                            VerticalAlignment="Center"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{Binding CycleStatusText, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis"
                                            ToolTipService.ToolTip="{Binding CycleStatusText, Mode=OneWay}"
                                            TextWrapping="Wrap" />
                                        <Button
                                            Grid.Row="2"
                                            HorizontalAlignment="Right"
                                            Command="{Binding ExecuteCycleCommand, Mode=OneTime}"
                                            Content="次へ" />
                                    </Grid>
                                </Border>

                                <Border
                                    Margin="6"
                                    Padding="16"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Visibility="{Binding StandardSliderVisibility, Mode=OneWay}">
                                    <Grid RowDefinitions="Auto,*,Auto">
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            MaxLines="2"
                                            Text="{Binding Title, Mode=OneTime}"
                                            TextTrimming="CharacterEllipsis"
                                            ToolTipService.ToolTip="{Binding Title, Mode=OneTime}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            Grid.Row="1"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{Binding SliderValueDisplay, Mode=OneWay}" />
                                        <Slider
                                            Grid.Row="2"
                                            IsEnabled="{Binding CanAdjustVolume, Mode=OneWay}"
                                            Maximum="{Binding SliderMaximum, Mode=OneTime}"
                                            Minimum="{Binding SliderMinimum, Mode=OneTime}"
                                            PointerWheelChanged="VolumeSlider_PointerWheelChanged"
                                            StepFrequency="1"
                                            Value="{Binding SliderValue, Mode=TwoWay}" />
                                    </Grid>
                                </Border>

                                <Border
                                    Margin="6"
                                    Padding="10,6"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Visibility="{Binding CompactToggleVisibility, Mode=OneWay}">
                                    <Grid ColumnDefinitions="*,Auto"
                                          RowDefinitions="*,*"
                                          ColumnSpacing="8">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            MaxLines="1"
                                            Text="{Binding Title, Mode=OneTime}"
                                            TextTrimming="CharacterEllipsis"
                                            ToolTipService.ToolTip="{Binding Title, Mode=OneTime}" />
                                        <TextBlock
                                            Grid.Row="1"
                                            VerticalAlignment="Center"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            MaxLines="1"
                                            Text="{Binding CycleStatusText, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis"
                                            ToolTipService.ToolTip="{Binding CycleStatusText, Mode=OneWay}" />
                                        <Button
                                            Grid.Column="1"
                                            Grid.RowSpan="2"
                                            MinWidth="52"
                                            VerticalAlignment="Center"
                                            Command="{Binding ExecuteCycleCommand, Mode=OneTime}"
                                            Content="次へ"
                                            Padding="10,5" />
                                    </Grid>
                                </Border>

                                <Border
                                    Margin="6"
                                    Padding="10,4"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Visibility="{Binding CompactSliderVisibility, Mode=OneWay}">
                                    <Grid RowDefinitions="Auto,*">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="14"
                                                FontWeight="SemiBold"
                                                MaxLines="1"
                                                Text="{Binding Title, Mode=OneTime}"
                                                TextTrimming="CharacterEllipsis"
                                                ToolTipService.ToolTip="{Binding Title, Mode=OneTime}" />
                                            <TextBlock
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{Binding SliderValueDisplay, Mode=OneWay}" />
                                        </Grid>
                                        <Slider
                                            Grid.Row="1"
                                            Margin="0,-3,0,-5"
                                            VerticalAlignment="Center"
                                            IsEnabled="{Binding CanAdjustVolume, Mode=OneWay}"
                                            Maximum="{Binding SliderMaximum, Mode=OneTime}"
                                            Minimum="{Binding SliderMinimum, Mode=OneTime}"
                                            PointerWheelChanged="VolumeSlider_PointerWheelChanged"
                                            StepFrequency="1"
                                            Value="{Binding SliderValue, Mode=TwoWay}" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
