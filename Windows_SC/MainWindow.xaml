<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Windows_SC.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:Windows_SC.ViewModels"
    Title="Windows_SC">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Border
        x:Name="RootBorder"
        Padding="20"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="12"
        KeyDown="RootBorder_KeyDown">
        <Grid RowDefinitions="Auto,*" RowSpacing="16">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Spacing="4">
                    <TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.Title, Mode=OneTime}" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.HotKeyDescription, Mode=OneTime}" />
                </StackPanel>

                <Button
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Command="{x:Bind ViewModel.OpenSettingsCommand, Mode=OneTime}"
                    Content="設定" />
            </Grid>

            <ScrollViewer
                x:Name="LauncherScrollViewer"
                Grid.Row="1"
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled"
                VerticalScrollBarVisibility="Auto"
                VerticalScrollMode="Enabled">
                <ItemsControl
                    x:Name="LauncherItemsControl"
                    ItemsSource="{x:Bind ViewModel.Shortcuts, Mode=OneTime}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid
                                ItemHeight="160"
                                ItemWidth="220"
                                MaximumRowsOrColumns="2"
                                Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="160" Width="220">
                                <Button
                                    Margin="6"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Content="{Binding Title, Mode=OneTime}"
                                    Command="{Binding ExecuteCommand, Mode=OneTime}"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Visibility="{Binding ButtonVisibility, Mode=OneTime}" />

                                <Border
                                    Margin="6"
                                    Padding="16"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Visibility="{Binding ToggleVisibility, Mode=OneTime}">
                                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Text="{Binding Title, Mode=OneTime}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            Grid.Row="1"
                                            VerticalAlignment="Center"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{Binding CurrentAudioDeviceName, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="Wrap" />
                                        <Button
                                            Grid.Row="2"
                                            HorizontalAlignment="Right"
                                            Command="{Binding CycleAudioOutputCommand, Mode=OneTime}"
                                            Content="次へ" />
                                    </Grid>
                                </Border>

                                <Border
                                    Margin="6"
                                    Padding="16"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Visibility="{Binding SliderVisibility, Mode=OneTime}">
                                    <Grid RowDefinitions="Auto,*,Auto">
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Text="{Binding Title, Mode=OneTime}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            Grid.Row="1"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{Binding SliderValueDisplay, Mode=OneWay}" />
                                        <Slider
                                            Grid.Row="2"
                                            IsEnabled="{Binding CanAdjustVolume, Mode=OneWay}"
                                            Maximum="{Binding SliderMaximum, Mode=OneTime}"
                                            Minimum="{Binding SliderMinimum, Mode=OneTime}"
                                            StepFrequency="1"
                                            Value="{Binding SliderValue, Mode=TwoWay}" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
